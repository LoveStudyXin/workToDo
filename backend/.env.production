# 生产环境配置模板
# 复制此文件为 .env 并修改配置

# Database - 使用 MySQL (推荐) 或 PostgreSQL
# MySQL 示例:
DATABASE_URL=mysql+aiomysql://用户名:密码@localhost:3306/work_todo
# PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://用户名:密码@localhost:5432/work_todo

# JWT Settings - 必须修改为随机字符串！
# 生成方式: openssl rand -hex 32
SECRET_KEY=你的随机密钥请用openssl生成
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Service Configuration
AI_PROVIDER=deepseek
AI_API_KEY=你的API密钥
AI_BASE_URL=https://api.deepseek.com/v1

# DeepSeek
DEEPSEEK_API_KEY=你的API密钥
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
